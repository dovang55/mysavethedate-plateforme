SUPABASE_URL=https://XXXXXXXXXXXXXXXX.supabase.co
# Clé secrète "service_role" (Project Settings -> API) : ne JAMAIS l'exposer au navigateur
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Clé publique "anon" (Project Settings -> API) : conçue pour être exposée côté client (espace/)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Obligatoire : le serveur refuse de démarrer si absent (aucune valeur par défaut)
ADMIN_KEY=tonMotDePasseAdmin2026
PORT=3000

# Enregistrement automatique du sous-domaine d'un client (HTTPS) via l'API Dokploy
# dès qu'un site devient actif. Sans ces variables, l'appel est simplement ignoré
# (log d'avertissement) — il faut alors ajouter le sous-domaine à la main dans
# Dokploy → Domains, puis cliquer "Validate".
DOKPLOY_API_URL=https://admin.guezdovan.com/api
DOKPLOY_API_KEY=
DOKPLOY_APP_ID=QWO0LiHomUrprTCl7kACk
# IP publique du VPS (celle du enregistrement DNS "*" chez Hostinger) : sans
# elle, le domaine est créé mais reste non validé (pas de HTTPS tant qu'on ne
# clique pas "Validate" à la main dans Dokploy).
DOKPLOY_SERVER_IP=187.124.20.138

# Connexion "Continuer avec Google" (callback fait maison, voir /api/auth/google/*
# dans server/index.js) — identifiants du client OAuth créé dans Google Cloud
# Console (Clients → ton client Web). Sans ces deux variables, le bouton
# redirige vers /espace/ avec un message d'erreur explicite au lieu de planter.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Paiement réel (Stripe Checkout) pour le déblocage du partage et le mur de
# photos — voir /api/mon-compte/site/:id/payer, /acheter-mur et le webhook
# /api/stripe/webhook dans server/index.js. Sans STRIPE_SECRET_KEY, les
# routes de paiement répondent une erreur explicite au lieu de planter.
# Clé secrète : Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_live_ou_sk_test_...
# Signing secret : Stripe Dashboard → Developers → Webhooks → ton endpoint
# (https://mysavethedate.com/api/stripe/webhook), écouter "checkout.session.completed"
STRIPE_WEBHOOK_SECRET=whsec_...
