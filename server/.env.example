SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Clé publique "anon" (Project Settings -> API) : conçue pour être exposée côté client (espace/)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
ADMIN_KEY=tonMotDePasseAdmin2026
PORT=3000

# Enregistrement automatique du sous-domaine d'un client (HTTPS) via l'API Dokploy
# dès qu'un site devient actif. Sans ces variables, l'appel est simplement ignoré
# (log d'avertissement) — il faut alors ajouter le sous-domaine à la main dans
# Dokploy → Domains, puis cliquer "Validate".
DOKPLOY_API_URL=https://admin.guezdovan.com/api
DOKPLOY_API_KEY=
DOKPLOY_APP_ID=QWO0LiHomUrprTCl7kACk
# IP publique du VPS (celle du enregistrement DNS "*" chez Hostinger) : sans
# elle, le domaine est créé mais reste non validé (pas de HTTPS tant qu'on ne
# clique pas "Validate" à la main dans Dokploy).
DOKPLOY_SERVER_IP=187.124.20.138
